# .env — Конфігурація мультиагентної дослідницької системи
# Скопіюйте цей файл у .env і вкажіть свій OpenAI ключ.
# Всі поля відповідають class Settings(BaseSettings) у config.py.
# debug=true — для діагностики, false — для звичайної роботи.


# ── OpenAI ────────────────────────────────────────────────────────────────────
openai_api_key=sk-your-real-key-here

# ── Моделі агентів ────────────────────────────────────────────────────────────
# model_name — загальний fallback, якщо окрема модель агента не задана
model_name=gpt-4o
supervisor_model=gpt-4o
planner_model=gpt-4o-mini
researcher_model=gpt-4o
critic_model=gpt-4o-mini

# ── LLM timeout / retry ───────────────────────────────────────────────────────
# llm_timeout_sec: якщо часто зависає, збільшуйте на +15 (макс 300)
llm_timeout_sec=90
llm_max_retries=2

# ── Граф виконання ────────────────────────────────────────────────────────────
graph_recursion_limit=25
# critique_max_rounds: скільки разів Researcher може доопрацьовувати (1–5)
critique_max_rounds=2

# ── Пошук / веб-контент ───────────────────────────────────────────────────────
max_search_results=5
max_url_content_length=2000
# url_fetch_timeout_sec: таймаут на читання однієї веб-сторінки
url_fetch_timeout_sec=10

# ── Директорії ────────────────────────────────────────────────────────────────
output_dir=output
data_dir=data
index_dir=index
chunks_path=index/chunks.json

# ── RAG / індексування ────────────────────────────────────────────────────────
embedding_model=text-embedding-3-small
reranker_model=BAAI/bge-reranker-base
chunk_size=800
chunk_overlap=120
semantic_top_k=8
bm25_top_k=8
hybrid_top_k=10
rerank_top_n=4

# ── Режим налагодження ────────────────────────────────────────────────────────
debug=false
