# .env
# Міняти тільки 3 параметри при потребі:
# tool_timeout_sec: якщо часто зависає/timeout, збільшуйте на +5.
# max_iterations: auto 3 (зменшено, було 10, - жере гроші), якщо відповідь обривається занадто рано, збільшуйте на +1.
# інші налаштування config.py - class Settings(BaseSettings)
# debug: true коли треба діагностика, false для звичайної роботи.


# OpenAI Configuration
openai_api_key=sk-your-real-key-here

# Agent control
max_iterations=3
tool_timeout_sec=40
agent_first_wait_sec=60
agent_second_wait_sec=30

# Model Settings
model_name=gpt-5.1 #-4o поводиться наче балувана Галя
# Output Configuration
output_dir=output
# Debug Mode
debug=false

# Search / content limits
max_search_results=5
max_url_content_length=2000

# RAG
embedding_model=text-embedding-3-small
reranker_model=BAAI/bge-reranker-base
# або прописувати повний шлях
data_dir=data
index_dir=index
chunks_path=index/chunks.json

chunk_size=800
chunk_overlap=120
semantic_top_k=8
bm25_top_k=8
hybrid_top_k=10
rerank_top_n=4